{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "lib": ["dom", "ES2021"],
    "module": "node16", 
    "moduleResolution": "node16", 
    "skipLibCheck": true,
    "strictNullChecks": true,
    "target": "es2022", 
    "preserveConstEnums": true
  },
  "include": ["src/**/*.ts"] 
}